<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  class="p-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-overlay
         transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus"
>
  <i id="theme-icon-light" class="fa-solid fa-sun text-lg" aria-hidden="true"></i>
  <i id="theme-icon-dark"  class="fa-solid fa-moon text-lg hidden" aria-hidden="true"></i>
</button>

<script>
  (function () {
    var btn   = document.getElementById('theme-toggle');
    var light = document.getElementById('theme-icon-light');
    var dark  = document.getElementById('theme-icon-dark');
    var html  = document.documentElement;

    function sync() {
      var isDark = html.classList.contains('dark');
      light.classList.toggle('hidden', isDark);
      dark.classList.toggle('hidden', !isDark);
    }

    sync();

    btn.addEventListener('click', function () {
      var isDark = html.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      document.cookie = 'theme=' + (isDark ? 'dark' : 'light') + '; path=/; max-age=31536000; SameSite=Lax';
      sync();
    });

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
      if (!localStorage.getItem('theme')) {
        html.classList.toggle('dark', e.matches);
        sync();
      }
    });
  })();
</script>
