<footer class="border-t border-border bg-surface-raised mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">

      <!-- Brand -->
      <div class="flex items-center gap-2 text-sm text-text-secondary">
        <span class="flex h-6 w-6 items-center justify-center rounded bg-primary text-primary-fg text-xs font-bold">K</span>
        <span><strong class="text-text-primary"><%= site.name %></strong> — Composable UI for real products</span>
      </div>

      <!-- Links -->
      <nav aria-label="Footer navigation" class="flex items-center gap-4 text-sm text-text-secondary">
        <a href="/" class="hover:text-text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus rounded">
          Showcase
        </a>
        <a href="/theme" class="hover:text-text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus rounded">
          Themes
        </a>
        <a href="<%= site.authorUrl %>" target="_blank" rel="noopener noreferrer"
           class="hover:text-text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus rounded">
          <%= site.author %>
          <i class="fa-solid fa-arrow-up-right-from-square text-xs ml-0.5" aria-hidden="true"></i>
        </a>
      </nav>

    </div>
  </div>
</footer>
