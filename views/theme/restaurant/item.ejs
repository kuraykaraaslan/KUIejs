<%
  var _data    = locals.data    || {};
  var _item    = locals.item    || {};
  var _related = locals.related || [];
  var _rest    = _data.restaurant || {};
  var symbol   = '₺';
%>

<%- include('./_nav', { data: _data, activeCategory: _item.category }) %>

  <div class="mb-6">
    <a href="/theme/restaurant" class="inline-flex items-center gap-2 text-xs text-text-secondary hover:text-text-primary transition-colors">
      <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
      Back to menu
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
    <div class="flex items-center justify-center rounded-2xl bg-surface-overlay border border-border h-64 text-8xl select-none">
      <%= _item.imageEmoji %>
    </div>

    <div class="flex flex-col gap-4">
      <div>
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <% var catMeta = { STARTER: { text:'text-amber-700 dark:text-amber-400', bg:'bg-amber-50 dark:bg-amber-950/30', border:'border-amber-200 dark:border-amber-800' }, MAIN: { text:'text-primary', bg:'bg-primary-subtle', border:'border-primary/30' }, DESSERT: { text:'text-secondary', bg:'bg-secondary/10', border:'border-secondary/30' }, DRINK: { text:'text-info', bg:'bg-info/10', border:'border-info/30' }, SIDE: { text:'text-text-secondary', bg:'bg-surface-overlay', border:'border-border' } }; %>
          <% var cm = catMeta[_item.category] || catMeta.MAIN; %>
          <span class="inline-flex items-center rounded-full border text-xs font-medium px-2.5 py-1 <%= cm.text %> <%= cm.bg %> <%= cm.border %>">
            <%= _item.category.charAt(0) + _item.category.slice(1).toLowerCase() %>
          </span>
          <% if (_item.featured) { %>
          <span class="inline-flex items-center gap-1 rounded-full bg-primary text-primary-fg text-xs font-semibold px-2.5 py-1">
            <i class="fa-solid fa-star text-xs" aria-hidden="true"></i> Chef's Pick
          </span>
          <% } %>
          <% if (!_item.available) { %>
          <span class="inline-flex items-center rounded-full bg-error/10 border border-error/30 text-error text-xs font-medium px-2.5 py-1">
            Unavailable Today
          </span>
          <% } %>
        </div>
        <h1 class="text-2xl font-bold text-text-primary"><%= _item.name %></h1>
        <p class="text-sm text-text-secondary mt-2 leading-relaxed"><%= _item.description %></p>
      </div>

      <div class="text-3xl font-bold text-primary"><%= symbol %><%= _item.price.toLocaleString('tr-TR') %></div>

      <% if (_item.dietary && _item.dietary.length > 0) { %>
      <div>
        <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide mb-2">Dietary</p>
        <div class="flex flex-wrap gap-2">
          <% _item.dietary.forEach(function(d) { %>
          <span class="inline-flex items-center rounded-full border font-medium text-xs px-2.5 py-1 gap-1.5 text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-950/30 border-green-200 dark:border-green-800">
            <i class="fa-solid fa-leaf text-xs" aria-hidden="true"></i>
            <%= d === 'GLUTEN_FREE' ? 'Gluten-Free' : d.charAt(0) + d.slice(1).toLowerCase() %>
          </span>
          <% }); %>
        </div>
      </div>
      <% } %>

      <% if (_item.allergens && _item.allergens.length > 0) { %>
      <div>
        <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide mb-2">Contains Allergens</p>
        <div class="flex flex-wrap gap-1">
          <% _item.allergens.forEach(function(a) { %>
          <span class="inline-flex items-center rounded border font-mono font-medium text-xs px-2 py-0.5 text-text-secondary bg-surface-sunken border-border">
            <%= a.charAt(0) + a.slice(1).toLowerCase() %>
          </span>
          <% }); %>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <% if (_related.length > 0) { %>
  <section>
    <h2 class="text-base font-bold text-text-primary mb-4">More from <%= _item.category.charAt(0) + _item.category.slice(1).toLowerCase() %>s</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <% _related.forEach(function(rel) { %>
      <a href="/theme/restaurant/item/<%= rel.id %>" class="flex items-center gap-3 p-3 rounded-xl border border-border bg-surface-raised hover:bg-surface-overlay transition-colors">
        <span class="text-3xl select-none"><%= rel.imageEmoji %></span>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-text-primary truncate"><%= rel.name %></p>
          <p class="text-xs text-primary font-bold">₺<%= rel.price.toLocaleString('tr-TR') %></p>
        </div>
      </a>
      <% }); %>
    </div>
  </section>
  <% } %>

<%- include('./_nav-close') %>
