<%
  var _data       = locals.data       || {};
  var _restaurant = _data.restaurant  || {};
  var _activeCat  = locals.activeCategory || null;
  var _categories = _data.categories  || [];
%>
<div class="min-h-screen bg-surface-base flex flex-col">

  <header class="sticky top-0 z-20 border-b border-border bg-surface-raised/95 backdrop-blur-sm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 flex h-14 items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-primary text-primary-fg text-base font-bold select-none">
          🫒
        </span>
        <div>
          <p class="text-sm font-bold text-text-primary leading-none"><%= _restaurant.name %></p>
          <p class="text-xs text-text-secondary mt-0.5"><%= _restaurant.tagline %></p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <% if (_restaurant.isOpen) { %>
        <span class="inline-flex items-center gap-1.5 rounded-full border font-medium text-xs px-2.5 py-1 text-success bg-success/10 border-success/30">
          <span class="h-1.5 w-1.5 rounded-full bg-success" aria-hidden="true"></span>
          Open
        </span>
        <% } else { %>
        <span class="inline-flex items-center gap-1.5 rounded-full border font-medium text-xs px-2.5 py-1 text-error bg-error/10 border-error/30">
          <span class="h-1.5 w-1.5 rounded-full bg-error" aria-hidden="true"></span>
          Closed
        </span>
        <% } %>
      </div>
    </div>

    <nav class="border-t border-border bg-surface-base overflow-x-auto" aria-label="Menu categories">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 flex gap-0">
        <a href="/theme/restaurant"
           class="shrink-0 px-4 py-2.5 text-xs font-semibold border-b-2 transition-colors
             <%= !_activeCat ? 'border-primary text-primary' : 'border-transparent text-text-secondary hover:text-text-primary' %>">
          All
        </a>
        <% _categories.forEach(function(cat) { %>
        <a href="/theme/restaurant?category=<%= cat %>"
           class="shrink-0 px-4 py-2.5 text-xs font-semibold border-b-2 transition-colors
             <%= _activeCat === cat ? 'border-primary text-primary' : 'border-transparent text-text-secondary hover:text-text-primary' %>">
          <%= cat.charAt(0) + cat.slice(1).toLowerCase() %>
        </a>
        <% }); %>
      </div>
    </nav>
  </header>

  <main class="flex-1 max-w-4xl mx-auto w-full px-4 sm:px-6 py-6">
