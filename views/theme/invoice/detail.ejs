<%
  var _inv  = locals.invoice || {};
  var _data = locals.data    || {};
  var sym   = '₺';
  function fmtMoney(n) { return sym + (n||0).toLocaleString('tr-TR'); }
  var statusMeta = {
    DRAFT:     { text: 'text-gray-600',  bg: 'bg-gray-100',  border: 'border-gray-300'  },
    SENT:      { text: 'text-cyan-700',  bg: 'bg-cyan-50',   border: 'border-cyan-200'  },
    PAID:      { text: 'text-green-700', bg: 'bg-green-50',  border: 'border-green-200' },
    OVERDUE:   { text: 'text-red-700',   bg: 'bg-red-50',    border: 'border-red-200'   },
    PARTIAL:   { text: 'text-amber-700', bg: 'bg-amber-50',  border: 'border-amber-200' },
    CANCELLED: { text: 'text-gray-500',  bg: 'bg-gray-50',   border: 'border-gray-200'  },
  };
  var sm = statusMeta[_inv.status] || statusMeta.DRAFT;
%>

<%- include('./_nav', { pageTitle: _inv.number || 'Invoice' }) %>

  <!-- Breadcrumb + actions -->
  <div class="flex items-center justify-between mb-6">
    <nav class="flex items-center gap-2 text-xs text-text-secondary">
      <a href="/theme/invoice" class="hover:text-text-primary transition-colors">Invoices</a>
      <i class="fa-solid fa-chevron-right text-xs" aria-hidden="true"></i>
      <span class="text-text-primary font-medium"><%= _inv.number %></span>
    </nav>
    <div class="flex items-center gap-2">
      <a href="/theme/invoice/<%= _inv.id %>/print" target="_blank"
         class="inline-flex items-center gap-2 rounded-lg border border-border text-xs font-medium px-3 py-1.5 text-text-secondary hover:bg-surface-overlay transition-colors">
        <i class="fa-solid fa-print" aria-hidden="true"></i>Print
      </a>
    </div>
  </div>

  <!-- Invoice card -->
  <div class="rounded-xl border border-border bg-surface-raised overflow-hidden">
    <!-- Header -->
    <div class="flex items-start justify-between p-6 border-b border-border">
      <div>
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-primary-fg text-lg font-bold mb-3">ND</div>
        <p class="text-base font-bold text-text-primary"><%= _data.issuer.name %></p>
        <p class="text-xs text-text-secondary mt-1"><%= _data.issuer.address %></p>
        <p class="text-xs text-text-secondary"><%= _data.issuer.city %>, <%= _data.issuer.country %></p>
        <p class="text-xs text-text-secondary"><%= _data.issuer.email %></p>
      </div>
      <div class="text-right space-y-1.5">
        <p class="text-xl font-bold text-text-primary font-mono"><%= _inv.number %></p>
        <span class="inline-flex items-center rounded-full border font-semibold text-xs px-2.5 py-1 <%= sm.text %> <%= sm.bg %> <%= sm.border %>">
          <%= _inv.status.charAt(0) + _inv.status.slice(1).toLowerCase() %>
        </span>
        <div class="text-xs text-text-secondary space-y-0.5 mt-2">
          <div><span class="font-medium">Issued:</span> <%= _inv.issueDate %></div>
          <div><span class="font-medium">Due:</span> <%= _inv.dueDate %></div>
          <% if (_inv.paidDate) { %><div class="text-success"><span class="font-medium">Paid:</span> <%= _inv.paidDate %></div><% } %>
        </div>
      </div>
    </div>

    <!-- From / Bill To -->
    <div class="grid grid-cols-2 gap-6 p-6 border-b border-border">
      <div class="space-y-1">
        <p class="text-xs font-semibold text-text-secondary uppercase tracking-widest">From</p>
        <p class="text-sm font-bold text-text-primary"><%= _data.issuer.name %></p>
        <p class="text-xs text-text-secondary"><%= _data.issuer.taxId %></p>
        <p class="text-xs text-text-secondary"><%= _data.issuer.email %></p>
      </div>
      <div class="space-y-1">
        <p class="text-xs font-semibold text-text-secondary uppercase tracking-widest">Bill To</p>
        <p class="text-sm font-bold text-text-primary"><%= _inv.client.name %></p>
        <p class="text-xs text-text-secondary"><%= _inv.client.address %>, <%= _inv.client.city %></p>
        <p class="text-xs text-text-secondary"><%= _inv.client.taxId %></p>
        <p class="text-xs text-text-secondary"><%= _inv.client.email %></p>
      </div>
    </div>

    <!-- Line items -->
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-surface-overlay">
            <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary w-8">#</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary">Description</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-text-secondary w-16">Qty</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-text-secondary w-28">Unit Price</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-text-secondary w-28">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% (_inv.lineItems||[]).forEach(function(item, i) { %>
          <tr class="<%= i%2===0?'bg-surface-base':'bg-surface-raised' %>">
            <td class="px-4 py-2.5 text-xs text-text-secondary"><%= i+1 %></td>
            <td class="px-4 py-2.5 text-sm text-text-primary"><%= item.description %></td>
            <td class="px-4 py-2.5 text-sm text-center text-text-primary"><%= item.quantity %></td>
            <td class="px-4 py-2.5 text-sm text-right font-mono text-text-primary"><%= fmtMoney(item.unitPrice) %></td>
            <td class="px-4 py-2.5 text-sm text-right font-mono font-semibold text-text-primary"><%= fmtMoney(item.total) %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Totals -->
    <div class="flex justify-end p-6 border-t border-border">
      <div class="min-w-56 space-y-0">
        <div class="flex justify-between py-2 border-b border-border text-sm">
          <span class="text-text-secondary">Subtotal</span>
          <span class="font-mono text-text-primary"><%= fmtMoney(_inv.subtotal) %></span>
        </div>
        <% if (_inv.discount > 0) { %>
        <div class="flex justify-between py-2 border-b border-border text-sm">
          <span class="text-text-secondary">Discount</span>
          <span class="font-mono text-success">−<%= fmtMoney(_inv.discount) %></span>
        </div>
        <% } %>
        <div class="flex justify-between py-2 border-b border-border text-sm">
          <span class="text-text-secondary">VAT (<%= _inv.taxRate %>%)</span>
          <span class="font-mono text-text-primary"><%= fmtMoney(_inv.taxAmount) %></span>
        </div>
        <div class="flex justify-between py-3 border-b-2 border-border text-base font-bold">
          <span class="text-text-primary">Total</span>
          <span class="font-mono text-text-primary"><%= fmtMoney(_inv.total) %></span>
        </div>
        <% if (_inv.paid > 0) { %>
        <div class="flex justify-between py-2 border-b border-border text-sm">
          <span class="text-text-secondary">Paid</span>
          <span class="font-mono text-success">−<%= fmtMoney(_inv.paid) %></span>
        </div>
        <div class="flex justify-between py-2 text-sm font-semibold">
          <span class="<%= _inv.balance>0?'text-error':'text-success' %>">Balance Due</span>
          <span class="font-mono <%= _inv.balance>0?'text-error':'text-success' %>"><%= fmtMoney(_inv.balance) %></span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Notes -->
    <% if (_inv.notes) { %>
    <div class="px-6 pb-6 border-t border-border pt-4">
      <p class="text-xs font-semibold text-text-secondary uppercase tracking-widest mb-1.5">Notes</p>
      <p class="text-xs text-text-secondary leading-relaxed"><%= _inv.notes %></p>
    </div>
    <% } %>
  </div>

<%- include('./_nav-close') %>
