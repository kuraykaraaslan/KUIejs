<%
  var _inv  = locals.invoice || {};
  var _data = locals.data    || {};
  var sym   = '₺';
  function fmtMoney(n) { return sym + (n||0).toLocaleString('tr-TR'); }
%>

<div class="min-h-screen bg-white text-zinc-900 font-sans">

  <div class="print:hidden fixed top-4 right-4 flex gap-2 z-50">
    <a href="/theme/invoice/<%= _inv.id %>" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 text-xs font-medium px-3 py-1.5 bg-white hover:bg-gray-50">
      <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>Back
    </a>
    <button onclick="window.print()" class="inline-flex items-center gap-2 rounded-lg bg-blue-600 text-white text-xs font-medium px-3 py-1.5 hover:bg-blue-700">
      <i class="fa-solid fa-print" aria-hidden="true"></i>Print
    </button>
  </div>

  <div class="max-w-3xl mx-auto p-12 print:p-8">

    <!-- Header -->
    <div class="flex items-start justify-between mb-10">
      <div>
        <div class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-blue-600 text-white text-xl font-black mb-3">ND</div>
        <p class="text-xl font-black text-zinc-900"><%= _data.issuer.name %></p>
        <p class="text-xs text-zinc-500 mt-1"><%= _data.issuer.address %></p>
        <p class="text-xs text-zinc-500"><%= _data.issuer.city %>, <%= _data.issuer.country %></p>
        <p class="text-xs text-zinc-500"><%= _data.issuer.email %></p>
        <p class="text-xs text-zinc-500">Tax ID: <%= _data.issuer.taxId %></p>
      </div>
      <div class="text-right">
        <p class="text-3xl font-black text-zinc-900">INVOICE</p>
        <p class="text-sm font-mono font-bold text-zinc-700 mt-1"><%= _inv.number %></p>
        <div class="mt-3 space-y-1 text-xs text-zinc-500">
          <div><span class="font-semibold text-zinc-700">Issue Date:</span> <%= _inv.issueDate %></div>
          <div><span class="font-semibold text-zinc-700">Due Date:</span> <%= _inv.dueDate %></div>
          <div><span class="font-semibold text-zinc-700">Terms:</span> <%= (_inv.terms||'').replace(/_/g,' ') %></div>
        </div>
      </div>
    </div>

    <!-- From / Bill To -->
    <div class="grid grid-cols-2 gap-8 mb-10 pb-8 border-b border-zinc-200">
      <div>
        <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">From</p>
        <p class="text-sm font-bold text-zinc-900"><%= _data.issuer.name %></p>
        <p class="text-xs text-zinc-500 mt-0.5"><%= _data.issuer.taxId %></p>
        <p class="text-xs text-zinc-500"><%= _data.issuer.phone %></p>
        <p class="text-xs text-zinc-500"><%= _data.issuer.website %></p>
      </div>
      <div>
        <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Bill To</p>
        <p class="text-sm font-bold text-zinc-900"><%= _inv.client.name %></p>
        <p class="text-xs text-zinc-500 mt-0.5"><%= _inv.client.address %></p>
        <p class="text-xs text-zinc-500"><%= _inv.client.city %></p>
        <p class="text-xs text-zinc-500"><%= _inv.client.country %></p>
        <% if (_inv.client.taxId) { %><p class="text-xs text-zinc-500">Tax ID: <%= _inv.client.taxId %></p><% } %>
        <p class="text-xs text-zinc-500"><%= _inv.client.email %></p>
      </div>
    </div>

    <!-- Line items table -->
    <table class="w-full mb-8">
      <thead>
        <tr class="bg-zinc-900 text-white">
          <th class="px-4 py-2.5 text-left text-xs font-semibold w-8">#</th>
          <th class="px-4 py-2.5 text-left text-xs font-semibold">Description</th>
          <th class="px-4 py-2.5 text-center text-xs font-semibold w-16">Qty</th>
          <th class="px-4 py-2.5 text-right text-xs font-semibold w-28">Unit Price</th>
          <th class="px-4 py-2.5 text-right text-xs font-semibold w-28">Total</th>
        </tr>
      </thead>
      <tbody>
        <% (_inv.lineItems||[]).forEach(function(item, i) { %>
        <tr class="<%= i%2===0?'bg-white':'bg-zinc-50' %> border-b border-zinc-100">
          <td class="px-4 py-3 text-xs text-zinc-400"><%= i+1 %></td>
          <td class="px-4 py-3 text-sm text-zinc-800"><%= item.description %></td>
          <td class="px-4 py-3 text-sm text-center text-zinc-700"><%= item.quantity %></td>
          <td class="px-4 py-3 text-sm text-right font-mono text-zinc-700"><%= fmtMoney(item.unitPrice) %></td>
          <td class="px-4 py-3 text-sm text-right font-mono font-semibold text-zinc-900"><%= fmtMoney(item.total) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>

    <!-- Totals -->
    <div class="flex justify-end mb-10">
      <div class="w-64 space-y-0">
        <div class="flex justify-between py-2 border-b border-zinc-200 text-sm">
          <span class="text-zinc-500">Subtotal</span>
          <span class="font-mono text-zinc-800"><%= fmtMoney(_inv.subtotal) %></span>
        </div>
        <% if (_inv.discount > 0) { %>
        <div class="flex justify-between py-2 border-b border-zinc-200 text-sm">
          <span class="text-zinc-500">Discount</span>
          <span class="font-mono text-green-700">−<%= fmtMoney(_inv.discount) %></span>
        </div>
        <% } %>
        <div class="flex justify-between py-2 border-b border-zinc-200 text-sm">
          <span class="text-zinc-500">VAT (<%= _inv.taxRate %>%)</span>
          <span class="font-mono text-zinc-800"><%= fmtMoney(_inv.taxAmount) %></span>
        </div>
        <div class="flex justify-between py-3 bg-zinc-900 text-white px-3 font-bold text-base mt-1">
          <span>Total Due</span>
          <span class="font-mono"><%= fmtMoney(_inv.total) %></span>
        </div>
        <% if (_inv.paid > 0) { %>
        <div class="flex justify-between py-2 border-b border-zinc-200 text-sm mt-1">
          <span class="text-zinc-500">Paid</span>
          <span class="font-mono text-green-700">−<%= fmtMoney(_inv.paid) %></span>
        </div>
        <div class="flex justify-between py-2 text-sm font-bold">
          <span class="<%= _inv.balance>0?'text-red-700':'text-green-700' %>">Balance Due</span>
          <span class="font-mono <%= _inv.balance>0?'text-red-700':'text-green-700' %>"><%= fmtMoney(_inv.balance) %></span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Bank details & notes -->
    <div class="grid grid-cols-2 gap-8 pt-8 border-t border-zinc-200">
      <div>
        <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Bank Details</p>
        <div class="space-y-1 text-xs text-zinc-600">
          <div><span class="text-zinc-400">Bank:</span> <%= _data.issuer.bankDetails.bank %></div>
          <div><span class="text-zinc-400">IBAN:</span> <span class="font-mono"><%= _data.issuer.bankDetails.iban %></span></div>
          <div><span class="text-zinc-400">SWIFT:</span> <span class="font-mono"><%= _data.issuer.bankDetails.swift %></span></div>
        </div>
      </div>
      <% if (_inv.notes) { %>
      <div>
        <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Notes</p>
        <p class="text-xs text-zinc-600 leading-relaxed"><%= _inv.notes %></p>
      </div>
      <% } %>
    </div>

    <div class="mt-12 pt-6 border-t border-zinc-100 text-center">
      <p class="text-xs text-zinc-400">Thank you for your business — <%= _data.issuer.website %></p>
    </div>

  </div>
</div>

<style>
  @media print {
    @page { margin: 1cm; size: A4; }
    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>
