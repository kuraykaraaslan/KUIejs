<%
  var _activePage = locals.activePage || '';
  var nav = [
    { id: 'invoices', label: 'Invoices',  href: '/theme/invoice',  icon: 'fa-solid fa-file-invoice' },
    { id: 'clients',  label: 'Clients',   href: '#',               icon: 'fa-solid fa-building'      },
    { id: 'reports',  label: 'Reports',   href: '#',               icon: 'fa-solid fa-chart-bar'     },
    { id: 'settings', label: 'Settings',  href: '#',               icon: 'fa-solid fa-gear'          },
  ];
%>
<div class="flex h-screen overflow-hidden bg-surface-base">

  <aside class="hidden md:flex w-56 shrink-0 flex-col border-r border-border bg-surface-raised">
    <div class="flex h-14 items-center gap-3 border-b border-border px-4">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-primary-fg text-sm">
        <i class="fa-solid fa-file-invoice-dollar" aria-hidden="true"></i>
      </span>
      <div class="min-w-0">
        <p class="text-xs font-bold text-text-primary leading-none">Nexus Digital</p>
        <p class="text-xs text-text-secondary mt-0.5">Billing</p>
      </div>
    </div>
    <nav class="flex-1 overflow-y-auto py-3 px-2" aria-label="Invoice navigation">
      <ul class="space-y-0.5" role="list">
        <% nav.forEach(function(item) { var isActive = item.id === _activePage || (item.id === 'invoices' && !_activePage); %>
        <li role="listitem">
          <a href="<%= item.href %>"
             class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors
               <%= isActive ? 'bg-primary-subtle text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>"
             <%= isActive ? 'aria-current="page"' : '' %>>
            <i class="<%= item.icon %> w-4 shrink-0 text-xs" aria-hidden="true"></i>
            <span class="truncate"><%= item.label %></span>
          </a>
        </li>
        <% }); %>
      </ul>
    </nav>
  </aside>

  <div class="flex-1 flex flex-col min-w-0">
    <header class="flex h-14 items-center justify-between border-b border-border px-6 bg-surface-raised">
      <div>
        <a href="/theme/invoice" class="text-xs text-text-secondary hover:text-text-primary transition-colors">
          <i class="fa-solid fa-arrow-left text-xs mr-1" aria-hidden="true"></i>Invoice Theme
        </a>
        <h1 class="text-base font-bold text-text-primary mt-0.5 leading-none"><%= locals.pageTitle || 'Invoices' %></h1>
      </div>
      <a href="/theme/invoice/inv-001" class="inline-flex items-center gap-2 rounded-lg bg-primary text-primary-fg text-xs font-semibold px-3 py-1.5 hover:opacity-90 transition-opacity">
        <i class="fa-solid fa-plus" aria-hidden="true"></i>New Invoice
      </a>
    </header>
    <main class="flex-1 overflow-y-auto p-6">
