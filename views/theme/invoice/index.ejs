<%
  var _invoices     = locals.invoices     || [];
  var _statusFilter = locals.statusFilter || 'ALL';
  var _data         = locals.data         || {};

  var statuses = ['ALL','DRAFT','SENT','PAID','OVERDUE','PARTIAL','CANCELLED'];

  var statusMeta = {
    DRAFT:     { text: 'text-gray-600',  bg: 'bg-gray-100',    border: 'border-gray-300'    },
    SENT:      { text: 'text-cyan-700',  bg: 'bg-cyan-50',     border: 'border-cyan-200'    },
    PAID:      { text: 'text-green-700', bg: 'bg-green-50',    border: 'border-green-200'   },
    OVERDUE:   { text: 'text-red-700',   bg: 'bg-red-50',      border: 'border-red-200'     },
    PARTIAL:   { text: 'text-amber-700', bg: 'bg-amber-50',    border: 'border-amber-200'   },
    CANCELLED: { text: 'text-gray-500',  bg: 'bg-gray-50',     border: 'border-gray-200'    },
  };

  function fmtMoney(n) { return '₺' + n.toLocaleString('tr-TR'); }

  var totalPaid    = _data.invoices ? _data.invoices.filter(function(i){return i.status==='PAID';}).reduce(function(s,i){return s+i.total;},0) : 0;
  var totalOverdue = _data.invoices ? _data.invoices.filter(function(i){return i.status==='OVERDUE';}).reduce(function(s,i){return s+i.balance;},0) : 0;
  var totalSent    = _data.invoices ? _data.invoices.filter(function(i){return i.status==='SENT'||i.status==='PARTIAL';}).reduce(function(s,i){return s+i.balance;},0) : 0;
%>

<%- include('./_nav', { pageTitle: 'Invoices' }) %>

  <!-- Stats -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl border border-border bg-surface-raised p-4">
      <p class="text-xs text-text-secondary uppercase tracking-wide font-medium">Total Invoices</p>
      <p class="text-2xl font-bold text-text-primary mt-1"><%= (_data.invoices||[]).length %></p>
    </div>
    <div class="rounded-xl border border-border bg-surface-raised p-4">
      <p class="text-xs text-text-secondary uppercase tracking-wide font-medium">Collected</p>
      <p class="text-2xl font-bold text-success mt-1 font-mono"><%= fmtMoney(totalPaid) %></p>
    </div>
    <div class="rounded-xl border border-border bg-surface-raised p-4">
      <p class="text-xs text-text-secondary uppercase tracking-wide font-medium">Outstanding</p>
      <p class="text-2xl font-bold text-warning mt-1 font-mono"><%= fmtMoney(totalSent) %></p>
    </div>
    <div class="rounded-xl border border-border bg-surface-raised p-4">
      <p class="text-xs text-text-secondary uppercase tracking-wide font-medium">Overdue</p>
      <p class="text-2xl font-bold text-error mt-1 font-mono"><%= fmtMoney(totalOverdue) %></p>
    </div>
  </div>

  <!-- Status filter -->
  <div class="flex gap-1 flex-wrap mb-4">
    <% statuses.forEach(function(s) { var isActive = s === _statusFilter; %>
    <a href="/theme/invoice<%= s==='ALL' ? '' : '?status='+s %>"
       class="text-xs font-medium px-3 py-1.5 rounded-lg border transition-colors
         <%= isActive ? 'bg-primary text-primary-fg border-primary' : 'border-border text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>">
      <%= s.charAt(0) + s.slice(1).toLowerCase() %>
    </a>
    <% }); %>
  </div>

  <!-- Invoice table -->
  <div class="rounded-xl border border-border bg-surface-raised overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border bg-surface-overlay">
          <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary uppercase tracking-wide">Invoice</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary uppercase tracking-wide">Client</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary uppercase tracking-wide hidden sm:table-cell">Issued</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary uppercase tracking-wide hidden md:table-cell">Due</th>
          <th class="px-4 py-3 text-right text-xs font-semibold text-text-secondary uppercase tracking-wide">Amount</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary uppercase tracking-wide">Status</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% _invoices.forEach(function(inv) {
          var sm = statusMeta[inv.status] || statusMeta.DRAFT;
        %>
        <tr class="hover:bg-surface-overlay transition-colors">
          <td class="px-4 py-3 font-mono text-xs text-text-primary font-semibold"><%= inv.number %></td>
          <td class="px-4 py-3 text-xs text-text-primary"><%= inv.client.name %></td>
          <td class="px-4 py-3 text-xs text-text-secondary hidden sm:table-cell"><%= inv.issueDate %></td>
          <td class="px-4 py-3 text-xs text-text-secondary hidden md:table-cell <%= inv.status==='OVERDUE' ? 'text-error font-semibold' : '' %>"><%= inv.dueDate %></td>
          <td class="px-4 py-3 text-xs font-mono font-semibold text-right text-text-primary">₺<%= inv.total.toLocaleString('tr-TR') %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center rounded-full border font-semibold text-xs px-2.5 py-1 <%= sm.text %> <%= sm.bg %> <%= sm.border %>">
              <%= inv.status.charAt(0) + inv.status.slice(1).toLowerCase() %>
            </span>
          </td>
          <td class="px-4 py-3 text-right">
            <a href="/theme/invoice/<%= inv.id %>" class="text-xs text-primary hover:underline font-medium">View</a>
          </td>
        </tr>
        <% }); %>
        <% if (_invoices.length === 0) { %>
        <tr>
          <td colspan="7" class="px-4 py-10 text-center text-sm text-text-secondary">No invoices found.</td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>

<%- include('./_nav-close') %>
