<!-- ── DESKTOP SIDEBAR ──────────────────────────────────── -->
<aside
  id="sidebar"
  class="hidden lg:flex flex-col h-full shrink-0 border-r border-border bg-surface-raised overflow-hidden transition-all duration-200"
>

  <!-- Logo -->
  <div id="sidebar-logo" class="flex items-center border-b border-border shrink-0 h-14 px-5">
    <div class="sidebar-full-only">
      <p class="text-sm font-semibold text-text-primary whitespace-nowrap">UI Showcase</p>
      <p class="text-xs text-text-secondary whitespace-nowrap">EJS templates</p>
    </div>
    <div class="sidebar-compact-only hidden w-full justify-center">
      <span class="text-sm font-bold text-text-primary select-none">UI</span>
    </div>
  </div>

  <!-- Collapse button -->
  <div id="sidebar-collapse-row" class="flex items-center justify-end px-2 py-2 border-b border-border shrink-0">
    <button
      id="sidebar-collapse-btn"
      aria-label="Collapse sidebar"
      class="p-1.5 rounded text-text-secondary hover:text-text-primary hover:bg-surface-overlay transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus"
    >
      <i id="collapse-icon" class="fa-solid fa-chevron-left" style="width:1rem;height:1rem;transition:transform 200ms" aria-hidden="true"></i>
    </button>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto px-2 py-3 space-y-1" aria-label="Component navigation">

    <!-- Home link -->
    <% var isHome = selectedId === null; %>
    <a
      href="/"
      aria-current="<%= isHome ? 'page' : 'false' %>"
      title="Home"
      class="sidebar-item flex items-center gap-2.5 rounded-lg text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus px-3 py-2 mb-2 <%= isHome ? 'bg-primary-subtle text-primary font-medium' : 'text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>"
    >
      <span class="sidebar-item-icon flex items-center justify-center w-6 h-6 rounded-md text-xs font-bold shrink-0 <%= isHome ? 'bg-primary text-primary-fg' : 'bg-surface-sunken text-text-secondary' %>">
        <i class="fa-solid fa-house text-[10px]" aria-hidden="true"></i>
      </span>
      <span class="sidebar-full-only flex-1 truncate text-sm">Home</span>
    </a>

    <% if (navGroups.length === 0) { %>
      <div class="sidebar-full-only px-3 py-6 text-center">
        <p class="text-xs text-text-disabled">No items yet.</p>
        <p class="text-[10px] text-text-disabled mt-1">Add entries to showcase.menu.ts</p>
      </div>
    <% } %>

    <% navGroups.forEach(function(group, gi) { %>
      <div class="nav-group">

        <% if (group.sectionStart) { %>
          <div class="sidebar-full-only flex items-center gap-2 px-3 pt-3 pb-1">
            <div class="flex-1 h-px bg-border"></div>
            <span class="text-[10px] font-semibold uppercase tracking-widest text-text-disabled shrink-0"><%= group.sectionStart %></span>
            <div class="flex-1 h-px bg-border"></div>
          </div>
          <div class="sidebar-compact-only hidden px-2 py-1.5">
            <div class="h-px bg-border"></div>
          </div>
        <% } %>

        <% if (group.collapsible) { %>
          <button
            type="button"
            data-group="<%= gi %>"
            aria-expanded="true"
            class="group-toggle-btn sidebar-full-only w-full flex items-center justify-between px-3 py-1 rounded-md mb-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus <%= group.items.some(function(i){ return i.active; }) ? 'text-text-primary' : 'text-text-disabled hover:text-text-secondary' %>"
          >
            <span class="text-[10px] font-semibold uppercase tracking-widest"><%= group.label %></span>
            <i class="fa-solid fa-chevron-down" style="width:.75rem;height:.75rem;transition:transform 200ms" aria-hidden="true"></i>
          </button>
        <% } else { %>
          <p class="sidebar-full-only text-xs font-medium uppercase tracking-wider text-text-secondary px-3 mb-0.5"><%= group.label %></p>
        <% } %>

        <ul class="group-items space-y-0.5 mb-2 list-none p-0" role="list" data-group="<%= gi %>">
          <% group.items.forEach(function(item) { %>
            <%
              var isActive = item.active || item.id === selectedId;
              var href = item.href ? item.href : '/' + item.id;
              var isExternal = !!(item.href && !item.href.startsWith('/'));
            %>
            <li>
              <a
                href="<%= href %>"
                <% if (isExternal) { %>target="_blank" rel="noopener noreferrer"<% } %>
                aria-current="<%= isActive ? 'page' : 'false' %>"
                title="<%= item.title %>"
                class="sidebar-item flex items-center gap-2.5 rounded-lg text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus px-3 py-2 <%= isActive ? 'bg-primary-subtle text-primary font-medium' : 'text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>"
              >
                <span class="sidebar-item-icon flex items-center justify-center w-6 h-6 rounded-md text-xs font-bold shrink-0 <%= isActive ? 'bg-primary text-primary-fg' : 'bg-surface-sunken text-text-secondary' %>"><%= item.abbr %></span>
                <span class="sidebar-full-only flex-1 truncate text-sm"><%= item.title %></span>
                <% if (item.status === 'beta') { %>
                  <span class="sidebar-full-only shrink-0 text-[9px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded bg-info-subtle text-info-fg" aria-label="Beta">beta</span>
                <% } else if (item.status === 'deprecated') { %>
                  <span class="sidebar-full-only shrink-0 text-[9px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded bg-warning-subtle text-warning-fg" aria-label="Deprecated">depr</span>
                <% } %>
              </a>
            </li>
          <% }); %>
        </ul>

      </div>
    <% }); %>

  </nav>

  <!-- Footer -->
  <div class="border-t border-border shrink-0">
    <div class="sidebar-full-only p-3 flex items-center gap-2">
      <span class="w-7 h-7 rounded-full bg-primary-subtle flex items-center justify-center text-xs font-bold text-primary shrink-0" aria-hidden="true">D</span>
      <div class="min-w-0">
        <p class="text-xs font-semibold text-text-primary truncate">Developer</p>
        <p class="text-[10px] text-text-secondary truncate">EJS Templates</p>
      </div>
    </div>
    <div class="sidebar-compact-only hidden p-3 justify-center">
      <span class="w-7 h-7 rounded-full bg-primary-subtle flex items-center justify-center text-xs font-bold text-primary" aria-hidden="true">D</span>
    </div>
  </div>

</aside>

<!-- ── MOBILE OVERLAY SIDEBAR ───────────────────────────── -->
<div
  id="mobile-sidebar-overlay"
  class="lg:hidden fixed inset-0 z-50 opacity-0 pointer-events-none transition-opacity duration-200"
  aria-hidden="true"
>
  <div id="mobile-backdrop" class="absolute inset-0 bg-black/50"></div>

  <aside
    id="mobile-sidebar"
    class="absolute left-0 top-0 h-full w-72 bg-surface-raised flex flex-col shadow-xl transition-transform duration-200 -translate-x-full overflow-hidden"
  >
    <!-- Header: title + close -->
    <div class="flex items-center justify-between h-14 border-b border-border px-4 shrink-0">
      <h2 class="text-base font-semibold text-text-primary">Navigation</h2>
      <button
        onclick="closeMobileSidebar()"
        class="p-1.5 rounded text-text-secondary hover:text-text-primary hover:bg-surface-overlay transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus"
        aria-label="Close sidebar"
      >
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-2 py-3 space-y-4" aria-label="Component navigation (mobile)">

      <!-- Home link -->
      <a
        href="/"
        aria-current="<%= isHome ? 'page' : 'false' %>"
        onclick="closeMobileSidebar()"
        class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus mb-1 <%= isHome ? 'bg-primary-subtle text-primary font-medium' : 'text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>"
      >
        <span class="flex items-center justify-center w-6 h-6 rounded-md text-xs font-bold shrink-0 <%= isHome ? 'bg-primary text-primary-fg' : 'bg-surface-sunken text-text-secondary' %>">
          <i class="fa-solid fa-house text-[10px]" aria-hidden="true"></i>
        </span>
        <span class="flex-1 truncate">Home</span>
      </a>

      <% if (navGroups.length === 0) { %>
        <div class="px-3 py-6 text-center">
          <p class="text-xs text-text-disabled">No items yet</p>
        </div>
      <% } %>

      <% navGroups.forEach(function(group, gi) { %>
        <div>
          <% if (group.sectionStart) { %>
            <div class="flex items-center gap-2 px-3 pt-3 pb-1">
              <div class="flex-1 h-px bg-border"></div>
              <span class="text-[10px] font-semibold uppercase tracking-widest text-text-disabled shrink-0"><%= group.sectionStart %></span>
              <div class="flex-1 h-px bg-border"></div>
            </div>
          <% } %>

          <% if (group.collapsible) { %>
            <button
              type="button"
              data-group="m<%= gi %>"
              aria-expanded="true"
              class="group-toggle-btn w-full flex items-center justify-between px-3 py-1 rounded-md mb-1 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus <%= group.items.some(function(i){ return i.active; }) ? 'text-text-primary' : 'text-text-disabled hover:text-text-secondary' %>"
            >
              <span class="text-[10px] font-semibold uppercase tracking-widest"><%= group.label %></span>
              <i class="fa-solid fa-chevron-down" style="width:.75rem;height:.75rem;transition:transform 200ms" aria-hidden="true"></i>
            </button>
          <% } else { %>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-text-disabled px-3 mb-1"><%= group.label %></p>
          <% } %>

          <ul class="group-items space-y-0.5 mb-2 list-none p-0" role="list" data-group="m<%= gi %>">
            <% group.items.forEach(function(item) { %>
              <%
                var isActive = item.active || item.id === selectedId;
                var href = item.href ? item.href : '/' + item.id;
              %>
              <li>
                <a
                  href="<%= href %>"
                  aria-current="<%= isActive ? 'page' : 'false' %>"
                  onclick="closeMobileSidebar()"
                  class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus <%= isActive ? 'bg-primary-subtle text-primary font-medium' : 'text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>"
                >
                  <span class="flex items-center justify-center w-6 h-6 rounded-md text-xs font-bold shrink-0 <%= isActive ? 'bg-primary text-primary-fg' : 'bg-surface-sunken text-text-secondary' %>"><%= item.abbr %></span>
                  <span class="flex-1 truncate"><%= item.title %></span>
                  <% if (item.status === 'beta') { %>
                    <span class="shrink-0 text-[9px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded bg-info-subtle text-info-fg" aria-label="Beta">beta</span>
                  <% } else if (item.status === 'deprecated') { %>
                    <span class="shrink-0 text-[9px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded bg-warning-subtle text-warning-fg" aria-label="Deprecated">depr</span>
                  <% } %>
                </a>
              </li>
            <% }); %>
          </ul>
        </div>
      <% }); %>
    </nav>

    <div class="border-t border-border shrink-0 p-3 flex items-center gap-2">
      <span class="w-7 h-7 rounded-full bg-primary-subtle flex items-center justify-center text-xs font-bold text-primary shrink-0" aria-hidden="true">D</span>
      <div class="min-w-0">
        <p class="text-xs font-semibold text-text-primary truncate">Developer</p>
        <p class="text-[10px] text-text-secondary truncate">EJS Templates</p>
      </div>
    </div>
  </aside>
</div>
