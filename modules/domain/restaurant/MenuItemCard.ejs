<%
  var _item = locals.item || {};
  var _name        = _item.name        || 'Menu Item';
  var _description = _item.description || '';
  var _price       = _item.price       || 0;
  var _currency    = _item.currency    || 'TRY';
  var _category    = _item.category    || 'MAIN';
  var _dietary     = _item.dietary     || [];
  var _allergens   = _item.allergens   || [];
  var _emoji       = _item.imageEmoji  || '🍽️';
  var _available   = _item.available !== false;
  var _featured    = _item.featured    || false;

  var symbol = _currency === 'TRY' ? '₺' : _currency === 'USD' ? '$' : _currency === 'EUR' ? '€' : _currency;
%>
<div class="relative flex flex-col rounded-xl border border-border bg-surface-raised overflow-hidden transition-shadow hover:shadow-md<%= !_available ? ' opacity-60' : '' %><%= _featured ? ' ring-2 ring-primary/30' : '' %>">
  <% if (_featured) { %>
  <div class="absolute top-2 right-2 z-10">
    <span class="inline-flex items-center gap-1 rounded-full bg-primary text-primary-fg text-xs font-semibold px-2 py-0.5">
      <i class="fa-solid fa-star text-xs" aria-hidden="true"></i> Featured
    </span>
  </div>
  <% } %>

  <div class="flex items-center justify-center h-32 bg-surface-overlay text-5xl select-none">
    <%= _emoji %>
  </div>

  <div class="flex flex-col flex-1 gap-2 p-4">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-sm font-bold text-text-primary leading-snug"><%= _name %></h3>
      <span class="shrink-0 text-sm font-bold text-primary"><%= symbol %><%= _price.toLocaleString('tr-TR') %></span>
    </div>

    <% if (_description) { %>
    <p class="text-xs text-text-secondary line-clamp-2"><%= _description %></p>
    <% } %>

    <% if (_dietary.length > 0 || _allergens.length > 0) { %>
    <div class="flex flex-wrap gap-1 mt-auto pt-2">
      <% _dietary.forEach(function(d) { %>
      <span class="inline-flex items-center rounded-full border font-medium text-xs px-1.5 py-0.5 gap-1 text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-950/30 border-green-200 dark:border-green-800">
        <i class="fa-solid fa-leaf text-xs" aria-hidden="true"></i>
        <%= d === 'GLUTEN_FREE' ? 'GF' : d.charAt(0) + d.slice(1).toLowerCase() %>
      </span>
      <% }); %>
      <% _allergens.forEach(function(a) { %>
      <span class="inline-flex items-center rounded border font-mono font-medium text-xs px-1.5 py-0.5 text-text-secondary bg-surface-sunken border-border">
        <%= a.slice(0,3).charAt(0) + a.slice(1,3).toLowerCase() %>
      </span>
      <% }); %>
    </div>
    <% } %>
  </div>

  <% if (!_available) { %>
  <div class="absolute inset-0 flex items-center justify-center bg-surface-base/60">
    <span class="rounded-full bg-surface-raised border border-border text-xs font-semibold text-text-secondary px-3 py-1.5">
      Unavailable
    </span>
  </div>
  <% } %>
</div>
