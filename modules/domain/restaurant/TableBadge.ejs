<%
  var _tableNumber = locals.tableNumber || 1;
  var _capacity    = locals.capacity    || 2;
  var _status      = (locals.status || 'AVAILABLE').toUpperCase();

  var meta = {
    AVAILABLE: { dot: 'bg-success', text: 'text-success', bg: 'bg-success/10', border: 'border-success/30', label: 'Available' },
    OCCUPIED:  { dot: 'bg-error',   text: 'text-error',   bg: 'bg-error/10',   border: 'border-error/30',   label: 'Occupied'  },
    RESERVED:  { dot: 'bg-warning', text: 'text-warning', bg: 'bg-warning/10', border: 'border-warning/30', label: 'Reserved'  },
  };
  var m = meta[_status] || meta.AVAILABLE;
%>
<div class="inline-flex items-center gap-2 rounded-lg border px-3 py-1.5 text-xs font-medium <%= m.text %> <%= m.bg %> <%= m.border %>">
  <i class="fa-solid fa-chair text-xs" aria-hidden="true"></i>
  <span>Table <%= _tableNumber %></span>
  <span class="text-xs opacity-70">(<%= _capacity %> seats)</span>
  <span class="h-1.5 w-1.5 rounded-full flex-shrink-0 <%= m.dot %>"></span>
  <span><%= m.label %></span>
</div>
