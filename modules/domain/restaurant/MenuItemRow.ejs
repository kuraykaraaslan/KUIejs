<%
  var _item = locals.item || {};
  var _name        = _item.name        || 'Menu Item';
  var _description = _item.description || '';
  var _price       = _item.price       || 0;
  var _currency    = _item.currency    || 'TRY';
  var _dietary     = _item.dietary     || [];
  var _allergens   = _item.allergens   || [];
  var _emoji       = _item.imageEmoji  || '🍽️';
  var _available   = _item.available !== false;

  var symbol = _currency === 'TRY' ? '₺' : _currency === 'USD' ? '$' : _currency === 'EUR' ? '€' : _currency;
%>
<div class="flex items-center gap-4 p-3 rounded-lg border border-border bg-surface-raised hover:bg-surface-overlay transition-colors<%= !_available ? ' opacity-60' : '' %>">
  <span class="text-2xl select-none shrink-0"><%= _emoji %></span>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2">
      <span class="text-sm font-semibold text-text-primary truncate"><%= _name %></span>
      <% if (!_available) { %>
      <span class="text-xs text-text-secondary">(unavailable)</span>
      <% } %>
    </div>
    <% if (_description) { %>
    <p class="text-xs text-text-secondary truncate mt-0.5"><%= _description %></p>
    <% } %>
    <% if (_dietary.length > 0 || _allergens.length > 0) { %>
    <div class="flex flex-wrap gap-1 mt-1">
      <% _dietary.forEach(function(d) { %>
      <span class="inline-flex items-center rounded-full border text-xs px-1.5 py-px gap-0.5 text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-950/30 border-green-200 dark:border-green-800">
        <i class="fa-solid fa-leaf" style="font-size:9px" aria-hidden="true"></i>
        <%= d === 'GLUTEN_FREE' ? 'GF' : d.charAt(0) + d.slice(1).toLowerCase() %>
      </span>
      <% }); %>
      <% _allergens.forEach(function(a) { %>
      <span class="inline-flex items-center rounded border font-mono text-xs px-1 py-px text-text-secondary bg-surface-sunken border-border">
        <%= a.slice(0,3).charAt(0) + a.slice(1,3).toLowerCase() %>
      </span>
      <% }); %>
    </div>
    <% } %>
  </div>

  <span class="shrink-0 text-sm font-bold text-primary"><%= symbol %><%= _price.toLocaleString('tr-TR') %></span>
</div>
