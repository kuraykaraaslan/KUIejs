<%
  var _allergen = (locals.allergen || '').toUpperCase();
  var _size     = locals.size || 'md';

  var abbr = {
    GLUTEN:    'Glu',
    DAIRY:     'Dai',
    NUTS:      'Nut',
    EGGS:      'Egg',
    SOY:       'Soy',
    SHELLFISH: 'She',
    FISH:      'Fsh',
  };
  var label = abbr[_allergen] || _allergen.slice(0,3);
  var cls   = _size === 'sm' ? 'text-xs px-1.5 py-0.5' : 'text-xs px-2 py-0.5';
%>
<span class="inline-flex items-center rounded border font-mono font-medium <%= cls %> text-text-secondary bg-surface-sunken border-border"
      title="Allergen: <%= _allergen.charAt(0) + _allergen.slice(1).toLowerCase() %>">
  <%= label %>
</span>
